	column PL_LineID = ```
			
			VAR AcctNum = GL_Transactions[AccountNumber] //Store transactions acc number
			RETURN
			CALCULATE(
			    MIN(PL_Structure[PL_LineID]), //Find the PL_LineID that matches
			    FILTER(
			        PL_Structure,
			        AcctNum >= PL_Structure[GL_AccountStart] &&
			        AcctNum <= PL_Structure[GL_AccountEnd] &&  // Does this transaction's account fall in the range?
			        PL_Structure[IsSubtotal] = "No" // Only match to DETAIL lines, not subtotals
			    ) 
			)
			```
		formatString: 0
		lineageTag: 3f91d323-d357-4baf-a26f-3f2f2a5809bd
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition GL_Transactions = calculated
		mode: import
		source = ```
				
				VAR BaseData = 
				ADDCOLUMNS(
				    GENERATESERIES(1, 500),
				    "TransactionID", [Value],
				    "Date", DATE(2023, 1, 1) + RANDBETWEEN(0, 730),
				    "AccountNumber", 
				        SWITCH(
				            TRUE(),
				            [Value] <= 150, RANDBETWEEN(4100, 4199), // Product Sales
				            [Value] <= 250, RANDBETWEEN(4200, 4299), // Service Revenue
				            [Value] <= 270, RANDBETWEEN(4300, 4399), // Other Income
				            [Value] <= 350, RANDBETWEEN(5100, 5199), // Product Costs
				            [Value] <= 390, RANDBETWEEN(5200, 5299), // Service Costs
				            [Value] <= 430, RANDBETWEEN(6100, 6199), // Salaries
				            [Value] <= 455, RANDBETWEEN(6200, 6299), // Rent & Utilities
				            [Value] <= 475, RANDBETWEEN(6300, 6399), // Marketing
				            [Value] <= 490, RANDBETWEEN(6400, 6499), // Administrative
				            [Value] <= 495, RANDBETWEEN(7100, 7199), // Interest
				            RANDBETWEEN(7200, 7299) // Tax
				        ),
				    "BaseAmount", RANDBETWEEN(100, 50000)
				)
				RETURN
				ADDCOLUMNS(
				    BaseData,
				    "Amount", 
				        SWITCH(
				            TRUE(),
				            [AccountNumber] >= 4000 && [AccountNumber] < 5000, [BaseAmount], // Revenue (positive)
				            -[BaseAmount] // Expenses (negative)
				        ),
				    "Description", 
				        SWITCH(
				            TRUE(),
				            [AccountNumber] >= 4100 && [AccountNumber] < 4200, "Product Sale",
				            [AccountNumber] >= 4200 && [AccountNumber] < 4300, "Service Rendered",
				            [AccountNumber] >= 4300 && [AccountNumber] < 4400, "Other Income",
				            [AccountNumber] >= 5100 && [AccountNumber] < 5200, "Product Cost",
				            [AccountNumber] >= 5200 && [AccountNumber] < 5300, "Service Cost",
				            [AccountNumber] >= 6100 && [AccountNumber] < 6200, "Salary Payment",
				            [AccountNumber] >= 6200 && [AccountNumber] < 6300, "Rent/Utilities",
				            [AccountNumber] >= 6300 && [AccountNumber] < 6400, "Marketing Expense",
				            [AccountNumber] >= 6400 && [AccountNumber] < 6500, "Admin Expense",
				            [AccountNumber] >= 7100 && [AccountNumber] < 7200, "Interest Payment",
				            "Tax Payment"
				        )
				)
				```

	annotation PBI_Id = c312146287d94fd9b8faa015d5df99b1

